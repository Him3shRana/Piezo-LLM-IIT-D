# Auto-generated by lammps_common.py
units           metal
atom_style      atomic
newton          on

read_data       starting_structure.lammps

pair_style      mliap unified /home/chemistry/phd/cyz218376/himesh_work/MACE-LAMMPS/MACE-OFF23_medium.model-mliap_lammps.pt 0
pair_coeff      * * C N O H

mass            1 12.011
mass            2 14.007
mass            3 15.999
mass            4 1.008

neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes

thermo          100
thermo_style    custom step temp pe ke etotal press vol
timestep        0.000500

print "===== STAGE: ENERGY MINIMISATION ====="
reset_timestep  0
dump            min_dump all custom 100 minimisation.lammpstrj id type element x y z
dump_modify     min_dump element C N O H
